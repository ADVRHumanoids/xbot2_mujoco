<?xml version="1.0"?>
<robot name="quadruped">

  <!-- floating joint -->
  <link name="world"/>
  <joint name="floating_base" type="floating">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <!-- ===================== BASE ===================== -->
  <link name="base_link">
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.2" iyz="0" izz="0.25"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.4 0.2 0.08"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.4 0.2 0.08"/></geometry>
    </collision>
  </link>

  <!-- ===================== LEGS ===================== -->
  <!--  Leg layout:
        FL = front-left  (x=+0.15, y=+0.1)
        FR = front-right (x=+0.15, y=-0.1)
        RL = rear-left   (x=-0.15, y=+0.1)
        RR = rear-right  (x=-0.15, y=-0.1)
  -->

  <!--  FRONT-LEFT  -->
  <link name="fl_hip_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 -0.1"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
    </collision>
  </link>

  <joint name="fl_hip" type="revolute">
    <parent link="base_link"/>
    <child link="fl_hip_link"/>
    <origin xyz="0.15 0.1 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.8" upper="0.8" effort="40" velocity="10"/>
  </joint>

  <link name="fl_knee_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 -0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.03 0.03 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.03 0.03 0.2"/></geometry>
    </collision>
  </link>

  <joint name="fl_knee" type="revolute">
    <parent link="fl_hip_link"/>
    <child link="fl_knee_link"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="40" velocity="10"/>
  </joint>

  <link name="fl_foot_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
  </link>

  <joint name="fl_ankle" type="fixed">
    <parent link="fl_knee_link"/>
    <child link="fl_foot_link"/>
    <origin xyz="0 0 -0.2"/>
  </joint>

  <!--  FRONT-RIGHT  -->
  <link name="fr_hip_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 -0.1"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
    </collision>
  </link>

  <joint name="fr_hip" type="revolute">
    <parent link="base_link"/>
    <child link="fr_hip_link"/>
    <origin xyz="0.15 -0.1 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.8" upper="0.8" effort="40" velocity="10"/>
  </joint>

  <link name="fr_knee_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 -0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.03 0.03 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.03 0.03 0.2"/></geometry>
    </collision>
  </link>

  <joint name="fr_knee" type="revolute">
    <parent link="fr_hip_link"/>
    <child link="fr_knee_link"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="40" velocity="10"/>
  </joint>

  <link name="fr_foot_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
  </link>

  <joint name="fr_ankle" type="fixed">
    <parent link="fr_knee_link"/>
    <child link="fr_foot_link"/>
    <origin xyz="0 0 -0.2"/>
  </joint>

  <!--  REAR-LEFT  -->
  <link name="rl_hip_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 -0.1"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
    </collision>
  </link>

  <joint name="rl_hip" type="revolute">
    <parent link="base_link"/>
    <child link="rl_hip_link"/>
    <origin xyz="-0.15 0.1 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.8" upper="0.8" effort="40" velocity="10"/>
  </joint>

  <link name="rl_knee_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 -0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.03 0.03 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.03 0.03 0.2"/></geometry>
    </collision>
  </link>

  <joint name="rl_knee" type="revolute">
    <parent link="rl_hip_link"/>
    <child link="rl_knee_link"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="40" velocity="10"/>
  </joint>

  <link name="rl_foot_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
  </link>

  <joint name="rl_ankle" type="fixed">
    <parent link="rl_knee_link"/>
    <child link="rl_foot_link"/>
    <origin xyz="0 0 -0.2"/>
  </joint>

  <!--  REAR-RIGHT  -->
  <link name="rr_hip_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 -0.1"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.04 0.04 0.2"/></geometry>
    </collision>
  </link>

  <joint name="rr_hip" type="revolute">
    <parent link="base_link"/>
    <child link="rr_hip_link"/>
    <origin xyz="-0.15 -0.1 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.8" upper="0.8" effort="40" velocity="10"/>
  </joint>

  <link name="rr_knee_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 -0.1"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.03 0.03 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1"/>
      <geometry><box size="0.03 0.03 0.2"/></geometry>
    </collision>
  </link>

  <joint name="rr_knee" type="revolute">
    <parent link="rr_hip_link"/>
    <child link="rr_knee_link"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="40" velocity="10"/>
  </joint>

  <link name="rr_foot_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
  </link>

  <joint name="rr_ankle" type="fixed">
    <parent link="rr_knee_link"/>
    <child link="rr_foot_link"/>
    <origin xyz="0 0 -0.2"/>
  </joint>

</robot>
